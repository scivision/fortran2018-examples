{
  "version": 6,

"configurePresets": [
{
  "name": "default",
  "binaryDir": "build",
  "generator": "Ninja",
  "cacheVariables": {
    "CMAKE_COMPILE_WARNING_AS_ERROR": true,
    "CMAKE_BUILD_TYPE": "Release"
  }
},
{
  "name": "debug", "inherits": "default",
  "displayName": "Debug mode",
  "cacheVariables": {
    "CMAKE_COMPILE_WARNING_AS_ERROR": false,
    "CMAKE_BUILD_TYPE": "Debug"
  }
},
{
  "name": "reldebug", "inherits": "default",
  "displayName": "RelWithDebInfo mode",
  "cacheVariables": {
    "CMAKE_COMPILE_WARNING_AS_ERROR": false,
    "CMAKE_BUILD_TYPE": "RelWithDebInfo"
  }
}

],
"buildPresets": [
  { "name": "default", "configurePreset": "default", "configuration": "Release" },
  { "name": "build", "inherits": "default" },
  { "name": "debug", "configurePreset": "debug", "configuration": "Debug" },
  { "name": "reldebug", "configurePreset": "reldebug", "configuration": "RelWithDebInfo" }
],
"testPresets": [
{
  "name": "default",
  "configurePreset": "default",
  "output": {
    "outputOnFailure": true,
    "verbosity": "verbose"
  },
  "execution": {
    "noTestsAction": "error",
    "scheduleRandom": true,
    "stopOnFailure": false,
    "timeout": 60
  }
},
{
  "name": "release", "inherits": "default",
  "configurePreset": "default",
  "configuration": "Release"
},
{
  "name": "debug", "inherits": "default",
  "configurePreset": "debug",
  "configuration": "Debug"
},
{
  "name": "reldebug", "inherits": "default",
  "configurePreset": "reldebug",
  "configuration": "RelWithDebInfo"
}
],
"workflowPresets": [
  {
    "name": "default", "steps": [
      { "type": "configure", "name": "default"},
      { "type": "build", "name": "default" },
      { "type": "test", "name": "default" }
    ]
  },
  { "name": "build", "steps": [
    { "type": "configure", "name": "default" },
    { "type": "build", "name": "build" } ]
  },
  {
    "name": "debug", "steps": [
      { "type": "configure", "name": "debug" },
      { "type": "build", "name": "debug" },
      { "type": "test", "name": "debug" }
    ]
  },
  {
    "name": "reldebug", "steps": [
      { "type": "configure", "name": "reldebug" },
      { "type": "build", "name": "reldebug" },
      { "type": "test", "name": "reldebug" }
    ]
  }
]
}
